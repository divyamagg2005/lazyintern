############################
# LazyIntern backend config #
############################

# ==========================
# Supabase
# ==========================
# Use Service Role key for server-side writes
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key_here"

# Optional (if used in dashboard/frontend)
SUPABASE_ANON_KEY="your_supabase_anon_public_key_here"


# ==========================
# Groq (OpenAI-compatible)
# ==========================
GROQ_API_KEY="your_groq_api_key_here"
GROQ_MODEL="llama-3.1-8b-instant"


# ==========================
# Hunter / Firecrawl / Snov.io
# ==========================
HUNTER_API_KEY="your_hunter_api_key_here"
FIRECRAWL_API_KEY="your_firecrawl_api_key_here"

# Snov.io Email Discovery API
# Obtain credentials from: https://snov.io/api-dashboard
# 1. Sign up for a Snov.io account
# 2. Navigate to API Dashboard
# 3. Create OAuth application to get Client ID and Client Secret
SNOV_CLIENT_ID="your_snov_client_id_here"
SNOV_CLIENT_SECRET="your_snov_client_secret_here"


# ==========================
# Twilio (Approval SMS)
# ==========================
TWILIO_ACCOUNT_SID="your_twilio_account_sid_here"
TWILIO_AUTH_TOKEN="your_twilio_auth_token_here"
TWILIO_FROM_NUMBER="+1234567890"      # e.g. +1415XXXXXXX
APPROVER_TO_NUMBER="+911234567890"    # Your phone number


# ==========================
# Public Base URL (Webhooks)
# ==========================
PUBLIC_BASE_URL="https://your-ngrok-or-domain-url.com"


# ==========================
# Gmail API Credentials
# ==========================
# Path to OAuth client JSON (downloaded from Google Cloud Console)
GMAIL_OAUTH_CLIENT_PATH="secrets/gmail_oauth_client.json"

# Token file generated after first authorization
GMAIL_TOKEN_PATH="secrets/gmail_token.json"

# Usually "me" for authenticated user
GMAIL_SENDER="me"


# ==========================
# Optional Safety Toggles
# ==========================
ENABLE_SMTP_PING="false"
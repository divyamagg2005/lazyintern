############################
# LazyIntern backend config #
############################

# Supabase (use Service Role key for server-side writes)
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY"

# Optional (if you later use anon/public in dashboard)
SUPABASE_ANON_KEY=""

# Groq (OpenAI-compatible endpoint)
GROQ_API_KEY=""
GROQ_MODEL="llama-3.1-70b-versatile"

# Hunter / Firecrawl
HUNTER_API_KEY=""
FIRECRAWL_API_KEY=""

# Twilio (approval SMS)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""      # e.g. +1415...
APPROVER_TO_NUMBER=""      # your phone number

# Public base URL for webhooks (Twilio needs the exact URL)
PUBLIC_BASE_URL="https://YOUR_NGROK_SUBDOMAIN.ngrok-free.app"

# Gmail API credentials
# - Put OAuth client json at this path (download from Google Cloud console)
# - First run will open browser to authorize and create token.json next to it
GMAIL_OAUTH_CLIENT_PATH="secrets/gmail_oauth_client.json"
GMAIL_TOKEN_PATH="secrets/gmail_token.json"
GMAIL_SENDER="me"

# Google Cloud Project ID (required for Gmail Pub/Sub push notifications)
GOOGLE_CLOUD_PROJECT_ID=""

# Gmail account warmup tracking (optional)
# Set to the date you created your Gmail account or started using it for outreach
# Format: YYYY-MM-DD (e.g., "2024-01-15")
# If not set, warmup will be calculated from first email sent date
GMAIL_ACCOUNT_CREATED_DATE=""

# Optional safety toggles
ENABLE_SMTP_PING="false"
